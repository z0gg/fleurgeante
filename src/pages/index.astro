---
const gallery = [
  { src: '/gallery-temp-01.svg', alt: 'Inspiration florale grand format pour mariage', tag: 'Mariage', title: 'Mur floral spectaculaire' },
  { src: '/gallery-temp-02.svg', alt: 'Inspiration florale grand format pour vitrine', tag: 'Vitrine', title: 'Décor signature boutique' },
  { src: '/gallery-temp-03.svg', alt: 'Inspiration florale grand format pour photobooth', tag: 'Photobooth', title: 'Coin photo immersif' },
  { src: '/gallery-temp-04.svg', alt: 'Inspiration florale grand format pour événement', tag: 'Événement', title: 'Entrée qui attire le regard' },
  { src: '/gallery-temp-05.svg', alt: 'Inspiration florale grand format pour scénographie', tag: 'Scénographie', title: 'Composition sur mesure' },
  { src: '/gallery-temp-06.svg', alt: 'Inspiration florale grand format pour activation de marque', tag: 'Marque', title: 'Installation mémorable' }
];

const services = [
  {
    title: 'Mariages & cérémonies',
    text: 'Des fleurs géantes qui subliment l’autel, l’allée, le coin photo ou la salle de réception avec une présence élégante et spectaculaire.'
  },
  {
    title: 'Vitrines & lancements',
    text: 'Un décor signature conçu pour attirer le regard, mettre la marque en scène et créer un impact immédiat en boutique ou en événement.'
  },
  {
    title: 'Photobooths & espaces photo',
    text: 'Des installations pensées pour devenir le point focal des photos, vidéos et souvenirs partagés par vos invités ou vos clients.'
  },
  {
    title: 'Décors sur mesure',
    text: 'Chaque composition s’adapte au lieu, aux volumes, à la palette de couleurs et à l’atmosphère recherchée.'
  }
];

const benefits = [
  'Un effet wow immédiat, même dans les grands espaces',
  'Une palette délicate pensée pour s’harmoniser au lieu et à l’ambiance',
  'Des créations idéales pour vitrines, cérémonies et événements photo',
  'Une approche artisanale, poétique et haut de gamme'
];

const process = [
  {
    step: '01',
    title: 'Découvrir votre univers',
    text: 'On échange sur le lieu, l’occasion, les dimensions et l’ambiance souhaitée.'
  },
  {
    step: '02',
    title: 'Composer le décor',
    text: 'Les fleurs, les hauteurs, les couleurs et les volumes sont pensés sur mesure pour votre espace.'
  },
  {
    step: '03',
    title: 'Créer l’impact',
    text: 'Le décor prend vie pour offrir une présence visuelle forte, mémorable et photogénique.'
  }
];

const faq = [
  {
    q: 'Pour quels types d’événements les fleurs géantes conviennent-elles ?',
    a: 'Elles conviennent parfaitement aux mariages, vitrines, lancements, anniversaires, événements corporatifs, séances photo et décors saisonniers.'
  },
  {
    q: 'Est-ce que chaque projet peut être personnalisé ?',
    a: 'Oui. Le concept, la palette, le format des fleurs et la composition globale sont adaptés au lieu et à l’effet recherché.'
  },
  {
    q: 'Pouvez-vous créer un décor qui s’accorde à une identité visuelle existante ?',
    a: 'Oui. Fleurgeante peut concevoir une installation en harmonie avec une marque, une palette ou un thème événementiel précis.'
  },
  {
    q: 'Comment obtenir une proposition ?',
    a: 'Il suffit de partager les grandes lignes du projet via le formulaire: type d’événement, lieu, date souhaitée et ambiance recherchée.'
  }
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fleurgeante — Fleurs géantes sur mesure</title>
    <meta
      name="description"
      content="Fleurgeante crée des fleurs géantes sur mesure pour mariages, vitrines, photobooths et événements avec une signature florale élégante et spectaculaire."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #fff7f5;
        --surface: rgba(255, 255, 255, 0.86);
        --surface-strong: #ffffff;
        --surface-soft: rgba(255, 255, 255, 0.62);
        --text: #3d2532;
        --muted: #715260;
        --line: rgba(61, 37, 50, 0.1);
        --line-strong: rgba(61, 37, 50, 0.18);
        --pink: #f07b96;
        --pink-soft: #f89fb1;
        --teal: #1db1b3;
        --teal-deep: #157f81;
        --shadow: 0 24px 60px rgba(87, 40, 61, 0.14);
        --shadow-soft: 0 18px 40px rgba(87, 40, 61, 0.1);
        --radius-xl: 32px;
        --radius-lg: 24px;
        --radius-md: 18px;
        --container: min(1180px, calc(100vw - 2rem));
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(248, 159, 177, 0.24), transparent 26%),
          radial-gradient(circle at bottom right, rgba(29, 177, 179, 0.16), transparent 22%),
          linear-gradient(180deg, #fff9f7 0%, #fff7f5 100%);
      }

      img { display: block; max-width: 100%; }
      a { color: inherit; text-decoration: none; }
      button, input, textarea { font: inherit; }
      .hidden { position: absolute; opacity: 0; pointer-events: none; width: 1px; height: 1px; }
      .container { width: var(--container); margin: 0 auto; }
      .section { padding: 5.6rem 0; }
      .section-tight { padding: 4.25rem 0; }
      .card {
        border-radius: var(--radius-lg);
        background: var(--surface-strong);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }
      .section-alt {
        background: linear-gradient(180deg, rgba(255,255,255,0.65), rgba(255,255,255,0));
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 0.95rem;
        border-radius: 999px;
        background: rgba(240, 123, 150, 0.1);
        border: 1px solid rgba(240, 123, 150, 0.16);
        color: #c44d70;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .section-title {
        font-size: clamp(2.2rem, 4vw, 4.1rem);
        line-height: 0.98;
        letter-spacing: -0.045em;
        margin: 0.9rem 0 1rem;
      }

      .section-copy,
      .service-card p,
      .process-card p,
      .faq-card p,
      .gallery-copy,
      .contact-copy p,
      .contact-aside p {
        color: var(--muted);
        line-height: 1.8;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 60;
        background: rgba(255, 247, 245, 0.84);
        border-bottom: 1px solid rgba(61, 37, 50, 0.06);
        backdrop-filter: blur(14px);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 84px;
        position: relative;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        min-width: 0;
      }

      .brand img {
        width: 56px;
        height: 56px;
        flex: 0 0 auto;
      }

      .brand-text {
        min-width: 0;
        font-weight: 800;
        font-size: 1.08rem;
        line-height: 1.05;
      }

      .brand-text small {
        display: block;
        margin-top: 0.22rem;
        color: var(--muted);
        font-size: 0.76rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      #nav-toggle {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }

      .nav-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.8);
        box-shadow: var(--shadow-soft);
        cursor: pointer;
        color: var(--text);
      }

      .nav-toggle svg {
        width: 1.25rem;
        height: 1.25rem;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }

      .site-nav a {
        color: var(--muted);
        font-weight: 650;
      }

      .site-nav a:hover { color: var(--text); }

      .nav-social {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin-left: 0.15rem;
        padding-left: 0.15rem;
      }

      .nav-social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.7rem;
        height: 2.7rem;
        border-radius: 999px;
        color: var(--text);
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid rgba(61, 37, 50, 0.08);
        box-shadow: var(--shadow-soft);
        transition: transform 160ms ease, border-color 160ms ease, color 160ms ease, background 160ms ease;
      }

      .site-nav .nav-social-link,
      .site-nav .nav-social-link:hover,
      .site-nav .nav-social-link:visited {
        color: var(--text);
      }

      .nav-social-link:hover {
        transform: translateY(-1px);
        color: var(--teal-deep);
        border-color: rgba(29, 177, 179, 0.28);
        background: rgba(255, 255, 255, 0.96);
      }

      .nav-social-link svg {
        width: 1.08rem;
        height: 1.08rem;
        fill: currentColor;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        min-height: 3.35rem;
        padding: 0 1.25rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
        transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, border-color 160ms ease;
      }

      .button:hover { transform: translateY(-1px); }
      .button-primary {
        color: #ffffff;
        background: linear-gradient(135deg, var(--pink), var(--teal));
        box-shadow: 0 18px 40px rgba(29, 177, 179, 0.24);
        text-shadow: 0 1px 2px rgba(61, 37, 50, 0.28);
      }

      .button-primary:hover,
      .button-primary:visited,
      .site-nav a.button-primary,
      .site-nav a.button-primary:hover,
      .site-nav a.button-primary:visited {
        color: #ffffff;
      }

      .button-secondary {
        color: var(--text);
        background: rgba(255, 255, 255, 0.84);
        border-color: rgba(61, 37, 50, 0.1);
      }

      .hero {
        position: relative;
        overflow: clip;
      }

      .hero::before,
      .hero::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        pointer-events: none;
      }

      .hero::before {
        width: 32rem;
        height: 32rem;
        right: -11rem;
        top: -10rem;
        background: radial-gradient(circle, rgba(240, 123, 150, 0.24), transparent 64%);
      }

      .hero::after {
        width: 24rem;
        height: 24rem;
        left: -8rem;
        bottom: -9rem;
        background: radial-gradient(circle, rgba(29, 177, 179, 0.18), transparent 68%);
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
        align-items: center;
        gap: 2.1rem;
      }

      .hero-copy h1 {
        font-size: clamp(3rem, 7vw, 6.2rem);
        line-height: 0.93;
        letter-spacing: -0.055em;
        margin: 1rem 0 1.2rem;
      }

      .hero-copy p {
        max-width: 39rem;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.86;
        margin: 0;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.95rem;
        margin-top: 2rem;
      }

      .hero-highlights {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 2.35rem;
      }

      .highlight {
        padding: 1.1rem 1rem 1.2rem;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(61, 37, 50, 0.09);
        box-shadow: var(--shadow-soft);
      }

      .highlight strong {
        display: block;
        margin-bottom: 0.35rem;
        font-size: 1.08rem;
      }

      .hero-art {
        position: relative;
      }

      .art-shell {
        position: relative;
        min-height: 41rem;
        padding: 1.25rem;
        border-radius: var(--radius-xl);
        background:
          linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.28)),
          linear-gradient(145deg, rgba(240, 123, 150, 0.28), rgba(29, 177, 179, 0.24));
        border: 1px solid rgba(255,255,255,0.78);
        box-shadow: var(--shadow);
      }

      .art-stage {
        position: absolute;
        inset: 1.15rem;
        border-radius: 26px;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.48) 100%),
          radial-gradient(circle at top, rgba(248, 159, 177, 0.62), rgba(29, 177, 179, 0.08));
      }

      .art-stage::before,
      .art-stage::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        pointer-events: none;
      }

      .art-stage::before {
        width: 18rem;
        height: 18rem;
        right: -3rem;
        top: -3rem;
        background: radial-gradient(circle, rgba(240,123,150,0.2), transparent 64%);
      }

      .art-stage::after {
        width: 16rem;
        height: 16rem;
        left: -4rem;
        bottom: -4rem;
        background: radial-gradient(circle, rgba(29,177,179,0.18), transparent 68%);
      }

      .art-logo {
        position: absolute;
        inset: 4rem 3rem auto 3rem;
        display: grid;
        place-items: center;
      }

      .art-logo img {
        width: min(74%, 390px);
        filter: drop-shadow(0 30px 46px rgba(91, 38, 61, 0.18));
      }

      .hero-pill-row {
        position: absolute;
        left: 1.25rem;
        right: 1.25rem;
        bottom: 1.25rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .hero-pill {
        padding: 1rem 1.05rem;
        border-radius: 22px;
        background: rgba(255,255,255,0.95);
        border: 1px solid rgba(61, 37, 50, 0.09);
        box-shadow: var(--shadow-soft);
      }

      .hero-pill strong {
        display: block;
        margin-bottom: 0.35rem;
        font-size: 1rem;
      }

      .hero-pill p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
        font-size: 0.97rem;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .intro-card,
      .service-card,
      .process-card,
      .faq-card,
      .contact-card,
      .contact-aside {
        padding: 2rem;
      }

      .benefit-list {
        margin: 1.35rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.95rem;
      }

      .benefit-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
      }

      .benefit-list li::before {
        content: "";
        width: 0.85rem;
        height: 0.85rem;
        margin-top: 0.45rem;
        border-radius: 999px;
        flex: 0 0 auto;
        background: linear-gradient(135deg, var(--pink), var(--teal));
      }

      .services-grid,
      .process-grid,
      .faq-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.35rem;
      }

      .service-card h3,
      .process-card h3,
      .faq-card h3 {
        margin: 0 0 0.85rem;
        font-size: 1.38rem;
      }

      .service-icon,
      .process-step {
        width: 3rem;
        height: 3rem;
        border-radius: 999px;
        display: inline-grid;
        place-items: center;
        font-weight: 800;
        margin-bottom: 1.1rem;
      }

      .service-icon {
        background: rgba(29, 177, 179, 0.13);
        color: var(--teal-deep);
      }

      .process-step {
        background: rgba(240, 123, 150, 0.13);
        color: #cc5d7f;
      }

      .gallery-wrap {
        padding: 1.5rem;
        border-radius: calc(var(--radius-xl) + 4px);
        background: linear-gradient(180deg, rgba(255,255,255,0.84), rgba(255,255,255,0.96));
        border: 1px solid rgba(61, 37, 50, 0.08);
        box-shadow: var(--shadow);
      }

      .gallery-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.25rem;
        margin-bottom: 1.6rem;
      }

      .gallery-copy {
        max-width: 42rem;
        margin: 0;
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .gallery-card {
        overflow: hidden;
        border-radius: 22px;
        background: white;
        border: 1px solid rgba(61, 37, 50, 0.07);
        box-shadow: var(--shadow-soft);
      }

      .gallery-card img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
      }

      .gallery-card figcaption {
        padding: 1rem 1rem 1.1rem;
        display: grid;
        gap: 0.45rem;
      }

      .gallery-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 2rem;
        padding: 0 0.8rem;
        border-radius: 999px;
        background: rgba(240, 123, 150, 0.11);
        color: #c55375;
        font-size: 0.8rem;
        font-weight: 700;
      }

      .gallery-title {
        font-weight: 700;
      }

      .band {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(240,123,150,0.96), rgba(29,177,179,0.96));
        color: white;
      }

      .band::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 15% 20%, rgba(255,255,255,0.22), transparent 20%),
          radial-gradient(circle at 82% 80%, rgba(255,255,255,0.18), transparent 18%);
      }

      .band-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
        align-items: center;
        gap: 1.5rem;
      }

      .band .eyebrow {
        color: white;
        background: rgba(255,255,255,0.18);
        border-color: rgba(255,255,255,0.24);
      }

      .band p,
      .band .section-title {
        color: white;
      }

      .process-panel {
        padding: 1.9rem;
        border-radius: var(--radius-lg);
        background: rgba(255,255,255,0.16);
        border: 1px solid rgba(255,255,255,0.22);
        backdrop-filter: blur(10px);
      }

      .contact-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.96fr) minmax(0, 1.04fr);
        gap: 1.5rem;
      }

      .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
      }

      .field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .field,
      .field-area {
        width: 100%;
        border: 1px solid rgba(61, 37, 50, 0.11);
        background: rgba(255,255,255,0.92);
        color: var(--text);
        border-radius: 18px;
        padding: 1rem 1.05rem;
        transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
      }

      .field {
        min-height: 3.4rem;
      }

      .field::placeholder,
      .field-area::placeholder {
        color: #876977;
      }

      .field:focus,
      .field-area:focus {
        outline: none;
        border-color: rgba(29, 177, 179, 0.62);
        box-shadow: 0 0 0 4px rgba(29, 177, 179, 0.12);
        background: white;
      }

      .field-area {
        min-height: 10rem;
        resize: vertical;
      }

      .form-status {
        display: none;
        border-radius: 18px;
        padding: 0.95rem 1rem;
        font-size: 0.98rem;
      }

      .form-status.is-success {
        background: rgba(29, 177, 179, 0.12);
        border: 1px solid rgba(29, 177, 179, 0.22);
        color: var(--teal-deep);
      }

      .form-status.is-error {
        background: rgba(220, 38, 38, 0.08);
        border: 1px solid rgba(220, 38, 38, 0.16);
        color: #b42318;
      }

      .contact-actions {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
      }

      .contact-mini-list {
        margin: 1.35rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.85rem;
      }

      .contact-mini-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        color: var(--muted);
      }

      .contact-mini-list li::before {
        content: "";
        width: 0.7rem;
        height: 0.7rem;
        margin-top: 0.5rem;
        border-radius: 999px;
        flex: 0 0 auto;
        background: linear-gradient(135deg, var(--pink), var(--teal));
      }

      .contact-aside {
        display: grid;
        gap: 1rem;
        align-content: start;
      }

      .social-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 0.4rem;
      }

      .social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.8rem;
        height: 2.8rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.9);
        border: 1px solid rgba(61, 37, 50, 0.1);
        color: var(--text);
        box-shadow: var(--shadow-soft);
        transition: transform 160ms ease, border-color 160ms ease, color 160ms ease, background 160ms ease;
      }

      .social-link svg {
        width: 1.08rem;
        height: 1.08rem;
        fill: currentColor;
      }

      .social-link:hover {
        transform: translateY(-1px);
        border-color: rgba(29, 177, 179, 0.35);
        color: var(--teal-deep);
        background: rgba(255,255,255,0.98);
      }

